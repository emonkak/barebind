{
  "name": "barebind",
  "version": "0.2.1",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./addons/*": {
      "import": "./src/addons/*.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./lib/index.js",
        "types": "./lib/index.d.ts"
      },
      "./addons/*": {
        "import": "./lib/addons/*.js",
        "types": "./lib/addons/*.d.ts"
      }
    }
  },
  "type": "module",
  "author": "Shota Nozaki",
  "license": "MIT",
  "scripts": {
    "build": "tsc --build",
    "build:all": "pnpm run build && pnpm run --recursive --parallel build",
    "clean": "rm -fr coverage lib",
    "clean:all": "pnpm run --include-workspace-root --recursive --parallel clean",
    "lint": "biome ci",
    "ci": "pnpm run clean:all && pnpm run lint && pnpm run build:all && pnpm test --coverage",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "watch": "tsc --build --watch --preserveWatchOutput",
    "watch:all": "pnpm run --include-workspace-root --recursive --parallel watch"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "sideEffects": false
}
