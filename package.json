{
  "name": "barebind",
  "version": "0.1.0",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./addons/*": {
      "import": "./src/addons/*.ts"
    },
    "./collections/*": {
      "import": "./src/collections/*.ts"
    },
    "./core": {
      "import": "./src/core.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./lib/index.js",
        "types": "./lib/index.d.ts"
      },
      "./addons/*": {
        "import": "./lib/addons/*.js",
        "types": "./lib/addons/*.d.ts"
      },
      "./collections/*": {
        "import": "./lib/collections/*.js",
        "types": "./lib/collections/*.d.ts"
      },
      "./core": {
        "import": "./lib/core.js",
        "types": "./lib/core.d.ts"
      }
    }
  },
  "type": "module",
  "author": "Shota Nozaki",
  "license": "MIT",
  "scripts": {
    "build": "tsc --build",
    "build:all": "pnpm run build && pnpm run --recursive --parallel build",
    "clean": "rm -fr coverage lib",
    "clean:all": "pnpm run --include-workspace-root --recursive --parallel clean",
    "lint": "biome ci",
    "ci": "pnpm run clean:all && pnpm run lint && pnpm run build:all && pnpm test --coverage",
    "test": "vitest run",
    "watch": "tsc --build --watch --preserveWatchOutput",
    "watch:all": "pnpm run --include-workspace-root --recursive --parallel watch"
  },
  "dependencies": {
    "navigation-api-types": "^0.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "sideEffects": false
}
