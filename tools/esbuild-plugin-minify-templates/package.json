{
  "name": "esbuild-plugin-minify-templates",
  "version": "0.0.0",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./lib/index.js",
        "types": "./lib/index.d.ts"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "watch": "tsc --build --watch --preserveWatchOutput",
    "clean": "rm -fr lib"
  },
  "dependencies": {
    "@swc/core": "^1.15.46",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
